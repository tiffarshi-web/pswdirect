RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect psadirect.ca → pswdirect.ca (301 permanent, preserve path)
RewriteCond %{HTTP_HOST} ^(www\.)?psadirect\.ca$ [NC]
RewriteRule ^(.*)$ https://pswdirect.ca/$1 [L,R=301]

# Force public SEO prefixes to SPA shell, even if stale files still exist at the edge
RewriteRule ^((home-care|ontario|private-home-care|in-home-care|senior-care|psw)-.*|personal-support-workers-ontario|about|faq)/?$ /index.html [L]

# If the request is for an existing file, serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# SPA fallback - serve index.html for all routes
RewriteRule ^ index.html [L]
